    {
      "type": "list",
      "category": "荣誉",
      "sourceLabel": "荣誉词表",
      "values": ["OBE", "FRS", "大英帝国勋章", "简·伊丽莎·宝洁奖学金", "博士学位", "一等荣誉", "研究员"]
